# ─────────────────────────────────────────────
# Kasane 認証情報（秘匿。.env はコミットしないこと）
# ─────────────────────────────────────────────
KASANE_USERNAME=root
KASANE_PASSWORD=neko

# ─────────────────────────────────────────────
# Kasane 接続先 / 投入先
# ─────────────────────────────────────────────
# API のベース URL
KASANE_BASE_URL=http://localhost:5173
# 投入先データベース名
KASANE_DATABASE=plateau
# 投入先テーブル名（事前に Boolean 型・max_zoom_level=KASANE_MAX_ZOOM で作成しておくこと）
KASANE_BLDG_TABLE=bldg
KASANE_TRAN_TABLE=tran

# ─────────────────────────────────────────────
# 変換・挿入の挙動
# ─────────────────────────────────────────────
# 変換時のズームレベル。投入先テーブルの max_zoom_level と一致させること
KASANE_MAX_ZOOM=25
# テーブルの max_zoom_level より小さい ID が来たときの挙動: Error | Ignore | Normalize
KASANE_ZOOM_POLICY=Normalize

# ─────────────────────────────────────────────
# 性能チューニング
# ─────────────────────────────────────────────
# 1 リクエストあたりの空間 ID 数
KASANE_INSERT_BATCH=1000
# 挿入リクエストの並列度
KASANE_INSERT_CONCURRENCY=4

# ─────────────────────────────────────────────
# デバッグ
# ─────────────────────────────────────────────
# 各 GML ファイルあたり先頭 N 件の空間 ID だけ挿入する（コメントアウトで無制限）
# KASANE_DEBUG_LIMIT=100

# ─────────────────────────────────────────────
# 都市処理（main.rs）
# ─────────────────────────────────────────────
# 処理対象の都市数（先頭から N 件）
CITY_LIMIT=20
# 都市の並列処理数
CITY_CONCURRENCY=3

# ─────────────────────────────────────────────
# ログ（tracing-subscriber）
# ─────────────────────────────────────────────
RUST_LOG=info
